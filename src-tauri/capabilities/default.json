{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "opener:default",
    "os:default",
    "allow-proxy",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://template.geebosblog.com/*"
        }
      ]
    }
  ]
}
