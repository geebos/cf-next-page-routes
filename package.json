{
  "name": "cf-next-pages-routes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n web,worker \"pnpm dev:web\" \"pnpm dev:worker\"",
    "dev:web": "next dev",
    "dev:worker": "wrangler dev --local --port 8787",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "deploy:web": "pnpm build",
    "deploy:worker": "wrangler deploy"
  },
