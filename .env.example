# Public site URL in format "schema://domain" (no path, no trailing slash, port allowed).
# Used for SEO canonical/hreflang URLs and as the API base URL.
# Required for production builds; optional in dev (web falls back to relative
# paths, Tauri falls back to DEFAULT_TAURI_BASE_URL in src/lib/api.ts).
NEXT_PUBLIC_BASE_URL=https://example.com
